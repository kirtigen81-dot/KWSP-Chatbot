# ─── App ───────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ─── OpenRouter ─────────────────────────────────────────────────────
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Free/cheap models: openai/gpt-4o-mini, google/gemini-flash-1.5, mistralai/mistral-7b-instruct
OPENROUTER_MODEL=openai/gpt-4o-mini

# ─── Auth ───────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=your-super-secret-key-at-least-32-chars-long

# Admin credentials (change these!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# ─── Vercel Blob (required for document storage in production) ───────
# Created automatically when you add Vercel Blob Storage in your dashboard
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxx
